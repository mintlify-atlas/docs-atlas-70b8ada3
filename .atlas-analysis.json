  "keyFeatures": [
    "Multi-tenant architecture with Row-Level Security (RLS) for strict data isolation",
    "Full commercial lifecycle: clients → requirements → quotes → approvals → jobs → invoices",
    "RBAC system with 9 predefined roles (SUPER_ADMIN, ADMIN_EMPRESA, GERENTE_GENERAL, DIR_COMERCIAL, EJECUTIVO_COM, DIR_OPERACIONES, TECNICO_CAMPO, AUDITOR, CLIENTE)",
    "White-label support: logo, colors, typography, PDFs, emails, and portal names fully configurable per tenant",
    "Public pre-engineering wizard (WizardStepper) with CFM calculation engine and lead scoring",
    "AI-free deterministic recommendation and diagnostic engine for industrial ventilation pre-sales",
    "Wompi payment gateway integration with webhook processing",
    "Comprehensive audit log with change tracking on all critical entities",
    "Industrial CMS for technical product catalog management (categories, families, series, SKUs)",
    "Financial analytics: cost tracking, profitability reports, and dashboard KPIs",
    "Export utilities for PDF (jsPDF) and Excel (XLSX) generation in the client"
  ],
  "publicApiSurface": [
    "submitWizardData(tenantCode, WizardSubmission): WizardResult",
    "getClients(tenantCode): ClientRow[]",
    "createClient(tenantCode, clientData): Client",
    "getRequirements(tenantCode): RequirementRow[]",
    "createRequirement(tenantCode, reqData): Requirement",
    "getQuotes(tenantCode): QuoteRow[]",
    "createQuote(tenantCode, quoteData): Quote",
    "getQuoteItems(quoteId): QuoteItem[]",
    "createLeadWithScore(tenantCode, leadData): Lead",
    "calculateLeadScore(email, role, urgency): LeadScoreResult",
    "createWompiCheckout(tenantCode, invoiceId, amount, customerEmail, customerName): WompiCheckout",
    "processWompiWebhook(payload): WebhookResult",
    "POST /api/webhooks/wompi",
    "getBrandingDefaults(tenantCode): BrandingConfig",
    "getTenantConfig(tenantId): TenantConfig",
    "calculateRequiredCfm(dimensions, environment): { cfm, cubicMeters }",
    "estimatePrice(service, urgency, cubicMeters): PriceEstimation",
    "getCatalog(tenantCode): CatalogCategory[]",
    "getProductDetail(productId): ProductDetail"
  ]
}
